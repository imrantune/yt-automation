# App
APP_ENV=development
LOG_LEVEL=INFO

# Database / Queue (required)
DATABASE_URL=postgresql+psycopg2://spartacus:spartacus@localhost:5432/spartacus_db
REDIS_URL=redis://:spartacus@localhost:6380/0

# Docker compose credentials
POSTGRES_USER=spartacus
POSTGRES_PASSWORD=spartacus
POSTGRES_DB=spartacus_db
REDIS_PASSWORD=spartacus

# OpenAI (required)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ElevenLabs (required)
ELEVENLABS_API_KEY=your-key-here
ELEVENLABS_VOICE_ID=your-voice-id-here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Image Provider: "dall-e" or "midjourney"
IMAGE_PROVIDER=dall-e
MIDJOURNEY_ENABLED=false
MIDJOURNEY_API_KEY=
MIDJOURNEY_API_BASE=https://api.goapi.ai

# Video provider order: comma-separated, first is primary
# Valid: hybrid, minimax, kling, wan21, runway
VIDEO_PROVIDER_ORDER=hybrid,minimax,kling,wan21,runway

# Wan 2.1 (local, requires ~22GB model download)
WAN21_ENABLED=false
WAN21_MODEL_ID=Wan-AI/Wan2.1-T2V-1.3B-Diffusers
WAN21_DEVICE=mps
WAN21_MAX_FRAMES=120

# Minimax (Hailuo)
MINIMAX_ENABLED=true
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io
MINIMAX_UNIT_PRICE=0.70

# Runway ML
RUNWAY_ENABLED=false
RUNWAY_API_KEY=
RUNWAY_API_BASE=https://api.dev.runwayml.com

# Kling AI
KLING_ENABLED=false
KLING_API_KEY=
KLING_API_BASE=https://api.klingapi.com
KLING_MODEL=kling-v2.6-pro

# Video output settings
VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=24
VIDEO_CODEC=libx264
VIDEO_BITRATE=5000k
AUDIO_CODEC=aac
AUDIO_BITRATE=192k
DEFAULT_SCENE_DURATION_SECONDS=45

# Output root
OUTPUT_ROOT=output

# YouTube Upload (optional - set to enable auto-upload)
# Download client_secret.json from Google Cloud Console > APIs & Credentials > OAuth 2.0
YOUTUBE_CLIENT_SECRET_PATH=
YOUTUBE_CREDENTIALS_PATH=youtube_credentials.json
YOUTUBE_UPLOAD_PRIVACY=unlisted
YOUTUBE_PLAYLIST_NAME=Spartacus Arena Season 1

# Hugging Face (for Wan 2.1 model download)
HF_TOKEN=
