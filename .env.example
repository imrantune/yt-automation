# App
APP_ENV=development
LOG_LEVEL=INFO

# Database / Queue (required)
DATABASE_URL=postgresql+psycopg2://spartacus:spartacus@localhost:5432/spartacus_db
REDIS_URL=redis://:spartacus@localhost:6380/0

# Docker compose credentials
POSTGRES_USER=spartacus
POSTGRES_PASSWORD=spartacus
POSTGRES_DB=spartacus_db
REDIS_PASSWORD=spartacus

# OpenAI (required)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ElevenLabs (required)
ELEVENLABS_API_KEY=your-key-here
ELEVENLABS_VOICE_ID=your-voice-id-here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Provider order: comma-separated, first is primary (wan21, minimax, runway)
VIDEO_PROVIDER_ORDER=wan21,minimax,runway

# Wan 2.1 (local, default primary)
WAN21_ENABLED=true
WAN21_MODEL_ID=Wan-AI/Wan2.1-T2V-1.3B
WAN21_DEVICE=mps
WAN21_MAX_FRAMES=49

# Minimax (secondary fallback)
MINIMAX_ENABLED=true
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.chat

# Runway (tertiary fallback)
RUNWAY_ENABLED=true
RUNWAY_API_KEY=
RUNWAY_API_BASE=https://api.dev.runwayml.com

# Video output settings
VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=24
VIDEO_CODEC=libx264
VIDEO_BITRATE=5000k
AUDIO_CODEC=aac
AUDIO_BITRATE=192k
DEFAULT_SCENE_DURATION_SECONDS=45

# Output root
OUTPUT_ROOT=output
